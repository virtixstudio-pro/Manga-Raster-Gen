<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RasterX Studio"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:strokeColor="#333333"
        app:strokeWidth="1dp">

        <ImageView
            android:id="@+id/previewImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/densityLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Densité / Lignes : 50"
            android:textColor="#BBBBBB"
            android:textSize="12sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/densitySlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="10"
            android:valueTo="150"
            android:value="50"
            app:thumbColor="#BB86FC"
            app:trackColorActive="#BB86FC" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModeRadial"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vitesse"
                    android:textColor="#FFFFFF"
                    app:strokeColor="#BB86FC"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModeDots"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Trames"
                    android:textColor="#FFFFFF"
                    app:strokeColor="#BB86FC"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModeBox"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Case"
                    android:textColor="#FFFFFF"
                    app:strokeColor="#BB86FC"/>
            </LinearLayout>
        </HorizontalScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportNst"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="EXPORTER FORMAT .NST"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="#BB86FC"
            android:textColor="#000000"/>
    </LinearLayout>
</LinearLayout>
